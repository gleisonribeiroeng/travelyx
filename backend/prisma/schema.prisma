generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(uuid())
  googleId             String                @unique
  email                String                @unique
  name                 String
  picture              String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  isActive             Boolean               @default(true)
  googleAccessToken    String?
  googleRefreshToken   String?
  planExpiresAt        DateTime?
  stripeCustomerId     String?               @unique
  role                 String                @default("USER")
  plan                 String                @default("FREE")
  supportConversations SupportConversation[]
  trips                Trip[]
}

model Trip {
  id             String          @id @default(uuid())
  name           String          @default("")
  destination    String          @default("")
  dateStart      String          @default("")
  dateEnd        String          @default("")
  status         String          @default("planejamento")
  currency       String          @default("BRL")
  flights        String          @default("[]")
  stays          String          @default("[]")
  carRentals     String          @default("[]")
  transports     String          @default("[]")
  activities     String          @default("[]")
  attractions    String          @default("[]")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String
  itineraryItems ItineraryItem[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ItineraryItem {
  id              String      @id @default(uuid())
  type            String
  refId           String?
  date            String
  timeSlot        String?
  label           String
  durationMinutes Int?
  notes           String      @default("")
  order           Int         @default(0)
  isPaid          Boolean     @default(false)
  tripId          String
  attachment      Attachment?
  trip            Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Attachment {
  id              String        @id @default(uuid())
  fileName        String
  mimeType        String
  sizeBytes       Int
  data            String
  createdAt       DateTime      @default(now())
  itineraryItemId String        @unique
  itineraryItem   ItineraryItem @relation(fields: [itineraryItemId], references: [id], onDelete: Cascade)
}

model SupportConversation {
  id              String           @id @default(uuid())
  userId          String
  discordThreadId String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        SupportMessage[]
}

model SupportMessage {
  id             String              @id @default(uuid())
  conversationId String
  content        String
  fromUser       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

